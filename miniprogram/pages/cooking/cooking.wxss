/* pages/cooking/cooking.wxss */

.page {
  min-height: 100vh;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ── 顶部 ── */
.cooking-header {
  padding: 24rpx 32rpx 16rpx;
  background: var(--color-card);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.recipe-name {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 16rpx;
}
.progress-bar {
  height: 8rpx;
  background: var(--color-border);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}
.progress-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: 4rpx;
  transition: width 0.4s ease;
}
.step-counter {
  font-size: 24rpx;
  color: var(--color-text-hint);
}

/* ── 步骤 Swiper ── */
.step-swiper {
  flex: 1;
  height: calc(100vh - 380rpx); /* 减去 header + navBar 高度 */
}
.step-content {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx;
  gap: 32rpx;
}

.step-visual {
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.step-emoji { font-size: 110rpx; }

.step-text-box {
  flex: 1;
  width: 100%;
}
.step-number {
  display: block;
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 600;
  margin-bottom: 12rpx;
}
.step-desc {
  display: block;
  font-size: 32rpx;
  line-height: 1.7;
  color: var(--color-text-primary);
}
.step-tip {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #FFFDE7;
  border-radius: var(--radius-md);
}
.tip-icon { font-size: 28rpx; flex-shrink: 0; }
.tip-text { font-size: 26rpx; color: #795548; line-height: 1.5; }

/* ── 计时器 ── */
.timer-row { width: 100%; }
.timer-btn {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 32rpx;
  border-radius: var(--radius-xl);
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  transition: all 0.2s;
}
.timer-btn.timer-running {
  background: var(--color-primary-light);
  border-color: var(--color-primary);
  color: var(--color-primary);
}
.timer-icon { font-size: 36rpx; }
.timer-label { font-size: 28rpx; }

/* ── 底部导航 ── */
.nav-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(12px);
  border-top: 1rpx solid var(--color-border);
}
.nav-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 12rpx;
  flex-shrink: 0;
}
.nav-icon { font-size: 40rpx; }
.nav-label { font-size: 20rpx; color: var(--color-text-hint); }
.nav-step-btn { flex: 1; font-size: 26rpx; padding: 20rpx 0; }

/* ── 完成弹窗 ── */
.mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0);
  z-index: 100;
  pointer-events: none;
  transition: background 0.3s;
}
.mask.mask-show {
  background: rgba(0,0,0,0.5);
  pointer-events: auto;
}
.done-panel {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: var(--color-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: 48rpx 40rpx;
  z-index: 101;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  transform: translateY(100%);
  transition: transform 0.3s ease-out;
}
.done-panel.panel-show { transform: translateY(0); }
.done-emoji { font-size: 96rpx; }
.done-title { font-size: 40rpx; font-weight: 700; }
.done-sub { font-size: 28rpx; color: var(--color-text-hint); }

.feedback-row {
  display: flex;
  gap: 32rpx;
  margin: 16rpx 0;
}
.feedback-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 24rpx 32rpx;
  background: var(--color-bg);
  border-radius: var(--radius-lg);
}
.fb-emoji { font-size: 56rpx; }
.fb-label { font-size: 24rpx; color: var(--color-text-secondary); }

.share-btn { width: 100%; }
.done-back {
  font-size: 26rpx;
  color: var(--color-text-hint);
  padding: 12rpx;
}
