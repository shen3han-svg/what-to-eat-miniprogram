/* pages/index/index.wxss */

.page {
  min-height: 100vh;
  padding: 0 32rpx 200rpx;
  background: var(--color-bg);
}

/* ── Header ── */
.header {
  padding: 60rpx 0 40rpx;
}
.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}
.header-sub {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-hint);
  margin-top: 8rpx;
}

/* ── 主拍照按钮 ── */
.photo-cta {
  margin: 8rpx 0 24rpx;
  border-radius: var(--radius-xl);
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C5A 100%);
  box-shadow: 0 8rpx 32rpx rgba(255,107,53,0.35);
  active-opacity: 0.85;
}
.photo-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}
.photo-icon { font-size: 80rpx; }
.photo-label {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-top: 16rpx;
}
.photo-hint {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

/* ── 次级输入按钮行 ── */
.input-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}
.input-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  transition: background 0.15s;
}
.input-btn.recording {
  background: #FFF0EB;
  border: 2rpx solid var(--color-primary);
}
.input-btn-icon { font-size: 48rpx; }
.input-btn-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 10rpx;
}

/* ── 已选/快捷食材区 ── */
.selected-section,
.quick-section { margin-bottom: 24rpx; }

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}
.clear-btn {
  font-size: 24rpx;
  color: var(--color-primary);
}

.ingredient-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.ingredient-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 24rpx;
  background: #FFF0EB;
  color: var(--color-primary);
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
}
.ingredient-tag.tag-camera {
  background: #E8F5E9;
  color: #2E7D32;
}
.ingredient-tag.tag-quick {
  background: var(--color-card);
  color: var(--color-text-secondary);
  border: 2rpx solid var(--color-border);
}
.ingredient-tag.tag-add {
  background: transparent;
  border: 2rpx dashed var(--color-primary);
  color: var(--color-primary);
}
.tag-del { color: var(--color-text-hint); margin-left: 4rpx; }

/* ── 偏好栏 ── */
.pref-bar {
  display: flex;
  align-items: center;
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  margin-bottom: 32rpx;
}
.pref-icon { font-size: 32rpx; margin-right: 12rpx; }
.pref-text { flex: 1; font-size: 24rpx; color: var(--color-text-secondary); }
.pref-arrow { font-size: 32rpx; color: var(--color-text-hint); }

/* ── 底部按钮 ── */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  background: rgba(247,248,250,0.92);
  backdrop-filter: blur(12px);
}
.start-btn {
  width: 100%;
  border-radius: var(--radius-xl);
  font-size: 32rpx;
  padding: 28rpx 0;
}
.start-btn[disabled] {
  opacity: 0.45;
}

/* ── 手动弹窗 ── */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0);
  z-index: 100;
  pointer-events: none;
  transition: background 0.3s;
}
.mask.mask-show {
  background: rgba(0,0,0,0.45);
  pointer-events: auto;
}

.manual-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 72vh;
  background: var(--color-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  z-index: 101;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease-out;
}
.manual-panel.panel-show {
  transform: translateY(0);
}
.panel-header {
  padding: 32rpx 32rpx 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}
.panel-title { font-size: 32rpx; font-weight: 600; }
.panel-close { font-size: 28rpx; color: var(--color-primary); }

.search-bar {
  padding: 16rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}
.search-input {
  background: var(--color-bg);
  border-radius: var(--radius-md);
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  width: 100%;
}

.category-scroll { flex: 1; overflow: hidden; }
.category-section { padding: 24rpx 32rpx; }
.category-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  display: block;
}
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.grid-item {
  padding: 14rpx 28rpx;
  border-radius: 40rpx;
  background: var(--color-bg);
  font-size: 26rpx;
  color: var(--color-text-primary);
  display: flex;
  align-items: center;
  gap: 6rpx;
  border: 2rpx solid transparent;
}
.grid-item-selected {
  background: var(--color-primary) !important;
  color: #fff !important;
  border-color: var(--color-primary) !important;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.35);
  font-weight: 600;
}
.check-mark { font-size: 20rpx; margin-right: 4rpx; }

/* 已选计数 */
.panel-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.selected-count {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

/* 顶部已选食材（置于弹窗上部） */
.panel-selected-bar {
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border);
  background: var(--color-card);
}
.top-selected-scroll {
  white-space: nowrap;
}
.top-selected-list {
  display: inline-flex;
  gap: 12rpx;
}
.top-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 24rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.3);
}
.top-tag-del {
  font-size: 20rpx;
  opacity: 0.85;
  margin-left: 4rpx;
}
