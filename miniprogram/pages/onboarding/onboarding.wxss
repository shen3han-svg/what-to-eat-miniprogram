/* pages/onboarding/onboarding.wxss */
.page { padding: 40rpx 32rpx 200rpx; }
.header { margin-bottom: 40rpx; }
.header-title { display: block; font-size: 40rpx; font-weight: 700; margin-bottom: 8rpx; }
.header-sub { display: block; font-size: 26rpx; color: var(--color-text-hint); }

.pref-section {
  padding: 32rpx;
  margin-bottom: 24rpx;
  border-radius: var(--radius-lg);
}
.pref-title { display: block; font-size: 28rpx; font-weight: 600; margin-bottom: 24rpx; }

.options-row { display: flex; flex-wrap: wrap; gap: 16rpx; }
.option-btn {
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  border: 2rpx solid var(--color-border);
  font-size: 26rpx;
  color: var(--color-text-primary);
  background: var(--color-bg);
}
.option-btn.selected {
  background: var(--color-primary-light);
  border-color: var(--color-primary);
  color: var(--color-primary);
  font-weight: 600;
}

.footer {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 16rpx 32rpx;
  background: rgba(247,248,250,0.92);
  backdrop-filter: blur(12px);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.save-btn { width: 100%; }
.skip-btn { font-size: 26rpx; color: var(--color-text-hint); padding: 8rpx; }
