/* pages/recommend/recommend.wxss */

.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 200rpx;
  background: var(--color-bg);
}

/* ── 食材摘要 ── */
.ingredient-summary {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 20rpx 0 32rpx;
}
.summary-label {
  font-size: 26rpx;
  color: var(--color-text-hint);
  white-space: nowrap;
}
.summary-names {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

/* ── 加载态 ── */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.loading-dots {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}
.dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: var(--color-primary);
  animation: bounce 1.2s infinite ease-in-out;
}
.dot2 { animation-delay: 0.2s; }
.dot3 { animation-delay: 0.4s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}
.loading-text { font-size: 28rpx; color: var(--color-text-hint); }

/* ── 空态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  gap: 16rpx;
}
.empty-icon { font-size: 96rpx; }
.empty-title { font-size: 32rpx; font-weight: 600; }
.empty-sub { font-size: 26rpx; color: var(--color-text-hint); }
.back-btn { margin-top: 32rpx; width: 280rpx; }

/* ── 菜谱卡片 ── */
.recipe-list { display: flex; flex-direction: column; gap: 24rpx; }

.recipe-card {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  gap: 24rpx;
  border-radius: var(--radius-lg);
  background: var(--color-card);
  box-shadow: var(--shadow-card);
  active-opacity: 0.9;
}

.recipe-cover {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-md);
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.cover-emoji { font-size: 56rpx; }

.recipe-info { flex: 1; min-width: 0; }

.recipe-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 10rpx;
}

.recipe-meta {
  display: flex;
  gap: 20rpx;
  margin-bottom: 12rpx;
}
.meta-item { font-size: 24rpx; color: var(--color-text-hint); }

.match-row {}
.match-badge {
  display: inline-flex;
  align-items: center;
  border-radius: 20rpx;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
}
.match-full { background: #E8F5E9; color: #2E7D32; }
.match-partial { background: #FFF8E1; color: #F57F17; }

.card-arrow {
  font-size: 40rpx;
  color: var(--color-text-hint);
  flex-shrink: 0;
}

/* ── 底部操作 ── */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 16rpx 32rpx;
  background: rgba(247,248,250,0.92);
  backdrop-filter: blur(12px);
}
.refresh-btn, .add-btn { flex: 1; }
